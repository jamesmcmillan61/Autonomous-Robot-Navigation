<?xml version="1.0"?>
<robot name="limo_car" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Parameters -->
  <xacro:property name="wheel_radius" value="0.045"/>
  <xacro:property name="wheel_width"  value="0.030"/>
  <xacro:property name="wheel_separation" value="0.30"/>

  <xacro:property name="base_length" value="0.45"/>
  <xacro:property name="base_width"  value="0.30"/>
  <xacro:property name="base_height" value="0.30"/>
  <xacro:property name="base_mass"   value="4.50"/>
  
 
  <xacro:property name="base_clearance" value="0.02"/>       <!-- 2 cm -->

  <xacro:property name="wheel_mass" value="0.45"/>
  
  <xacro:property name="lidar_height" value="0.03"/>
  <xacro:property name="lidar_radius" value="0.03"/>

  <!-- LiDAR position: top front of the base -->
  <xacro:property name="lidar_x" value="${(base_length/2.0) - 0.04}"/>
  <xacro:property name="lidar_y" value="0.0"/>
  <xacro:property name="lidar_z" value="${base_clearance + base_height + (lidar_height/2.0)}"/>


  <!-- Base link -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height/2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="Grey">
        <color rgba="0.6 0.6 0.6 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 ${base_height/2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 ${base_height/2.0}" rpy="0 0 0"/>
      <mass value="${base_mass}"/>
      <inertia ixx="0.06" ixy="0.0" ixz="0.0" iyy="0.10" iyz="0.0" izz="0.12"/>
    </inertial>
  </link>
  





  <!-- Reusable wheel macro -->
  <!-- Important: cylinder axis is Z, so we rotate it by +90 deg about X to align with Y axle -->
  <xacro:macro name="wheel" params="prefix x y">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="Black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <origin xyz="${x} ${y} ${wheel_radius}" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- Four wheels -->
  <xacro:wheel prefix="front_left"  x="${base_length/4.0}"  y="${wheel_separation/2.0}"/>
  <xacro:wheel prefix="front_right" x="${base_length/4.0}"  y="-${wheel_separation/2.0}"/>
  <xacro:wheel prefix="rear_left"   x="-${base_length/4.0}" y="${wheel_separation/2.0}"/>
  <xacro:wheel prefix="rear_right"  x="-${base_length/4.0}" y="-${wheel_separation/2.0}"/>
  
  
  
  <!-- LiDAR link -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="Blue">
        <color rgba="0.2 0.2 0.9 1.0"/>
      </material>
    </visual>

    <!-- tiny collision avoids sensor rays starting inside geometry -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.01 0.01 0.01"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.10"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <origin xyz="${lidar_x} ${lidar_y} ${lidar_z}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="lidar_link"/>
  </joint>
  
  
  
  
  <!-- Gazebo LiDAR sensor (separate top-level block, not nested) -->
  <gazebo reference="lidar_link">
    <sensor name="lidar" type="ray">
      <always_on>true</always_on>
      <update_rate>10</update_rate>
      <visualize>true</visualize>

      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-1.57079632679</min_angle>
            <max_angle>1.57079632679</max_angle>
          </horizontal>
        </scan>

        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>

      <plugin name="gazebo_ros_lidar" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/out:=/scan</remapping>
          
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>






  <!-- Gazebo plugins -->
  <gazebo>

    <!-- Front axle drive -->
    <plugin name="front_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <update_rate>50</update_rate>

      <left_joint>front_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>

      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_diameter>${2.0 * wheel_radius}</wheel_diameter>

      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>10.0</max_wheel_acceleration>

      <command_topic>cmd_vel</command_topic>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>

    <!-- Rear axle drive -->
    <plugin name="rear_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <update_rate>50</update_rate>

      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>rear_right_wheel_joint</right_joint>

      <wheel_separation>${wheel_separation}</wheel_separation>
      <wheel_diameter>${2.0 * wheel_radius}</wheel_diameter>

      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>10.0</max_wheel_acceleration>

      <command_topic>cmd_vel</command_topic>

      <!-- Do not publish odom twice -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>

      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>

    <!-- Joint states for all wheels -->
    <plugin name="joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>50</update_rate>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
    </plugin>

  </gazebo>


  <!-- Camera parameters -->
  <xacro:property name="camera_width"  value="0.04"/>
  <xacro:property name="camera_height" value="0.03"/>
  <xacro:property name="camera_depth"  value="0.02"/>

  <!-- Place the camera at the front, slightly above the base and below the LiDAR -->
  <xacro:property name="camera_x" value="${(base_length/2.0) - 0.03}"/>
  <xacro:property name="camera_y" value="0.0"/>
  <xacro:property name="camera_z" value="${base_clearance + base_height + (camera_height/2.0)}"/>

  <!-- Camera link -->
  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_width} ${camera_height} ${camera_depth}"/>
      </geometry>
      <material name="Red">
        <color rgba="0.8 0.2 0.2 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${camera_width} ${camera_height} ${camera_depth}"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="${camera_x} ${camera_y} ${camera_z}" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>


  <!-- Camera sensor plugin -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>false</visualize>

      <camera>
        <horizontal_fov>1.0472</horizontal_fov>   <!-- 60 degrees in radians -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100.0</far>
        </clip>
      </camera>

      <plugin name="gazebo_ros_camera" filename="libgazebo_ros_camera.so">
        <ros>
          <namespace>/</namespace>
          <remapping>~/image_raw:=/camera/image_raw</remapping>
          <remapping>~/camera_info:=/camera/camera_info</remapping>
        </ros>
        <frame_name>camera_link</frame_name>
        <hack_baseline>0.07</hack_baseline> 
      </plugin>
    </sensor>
  </gazebo>

</robot>